---
import Icon from "./Icon.astro";

interface Ingredient {
  name: string;
  value: number | string;
  unit?: string;
  scale: number;
}

interface Props {
  initialServings: number;
  ingredients: Ingredient[];
  showStepper?: boolean; // Nueva prop
}

const { initialServings, ingredients, showStepper = true } = Astro.props;

const getInitialUnit = (value: number | string, unit?: string) => {
  if (!unit) return "";
  if (!unit.includes("|")) return unit;
  const [singular, plural] = unit.split("|");
  return value === 1 ? singular : plural;
};
---

<recipe-stepper-element data-base-servings={initialServings}>
  <div class="recipe-stepper">
    {
      showStepper && (
        <div class="stepper-controls">
          <button
            type="button"
            class="btn-minus"
            aria-label="Menos personas"
            aria-controls="ingredients-list"
          >
            <Icon name="minus" size={24} strokeWidth="1.5" />
          </button>

          <div class="servings-info" aria-live="polite">
            <span class="servings-display">{initialServings}</span>
            <span class="servings-label">persona</span>
          </div>

          <button
            type="button"
            class="btn-plus"
            aria-label="Más personas"
            aria-controls="ingredients-list"
          >
            <Icon name="plus" size={24} strokeWidth="1.5" />
          </button>
        </div>
      )
    }

    <!-- {!showStepper && <h3 class="ingredients-title">Ingredientes</h3>} -->
    <h3 class="ingredients-title">Ingredientes</h3>
    <ul class="ingredients-list" id="ingredients-list">
      {
        ingredients.map((ing) => {
          const isNumeric = typeof ing.value === "number";
          const displayUnit = getInitialUnit(ing.value, ing.unit);

          return (
            <li>
              <span class="ing-name">{ing.name}: </span>
              {isNumeric ? (
                <span
                  class="ing-value"
                  data-base-value={ing.value}
                  data-scale-factor={ing.scale}
                  data-unit={ing.unit || ""}
                >
                  {ing.value}
                </span>
              ) : (
                <span class="ing-value-fixed">{ing.value}</span>
              )}
              {ing.unit && <span class="ing-unit"> {displayUnit}</span>}
            </li>
          );
        })
      }
    </ul>
  </div>
</recipe-stepper-element>

<script>
  if (!customElements.get("recipe-stepper-element")) {
    customElements.define(
      "recipe-stepper-element",
      class extends HTMLElement {
        connectedCallback() {
          const baseServings = parseInt(this.dataset.baseServings || "1");
          const minusBtn = this.querySelector(".btn-minus");
          const plusBtn = this.querySelector(".btn-plus");

          // Si no hay botones, no inicializamos la lógica de escalado interactivo
          if (!minusBtn || !plusBtn) return;

          const servingsDisplay = this.querySelector(".servings-display");
          const valueElements = this.querySelectorAll(".ing-value");
          const servingsLabel = this.querySelector(".servings-label");

          let currentServings = baseServings;

          const roundToKitchen = (num: number, unit: string) => {
            const u = unit.toLowerCase();
            if (u.includes("g") || u.includes("ml")) {
              return Math.round(num);
            }
            return Math.round(num * 2) / 2;
          };

          const getDisplayUnit = (num: number, unit: string) => {
            if (!unit.includes("|")) return unit;
            const parts = unit.split("|");
            return num === 1 ? parts[0] : parts[1];
          };

          const updateButtons = () => {
            if (minusBtn instanceof HTMLButtonElement)
              minusBtn.disabled = currentServings <= 1;
            if (plusBtn instanceof HTMLButtonElement)
              plusBtn.disabled = currentServings >= 6;
          };

          const updateQuantities = () => {
            if (servingsDisplay)
              servingsDisplay.textContent = currentServings.toString();
            if (servingsLabel)
              servingsLabel.textContent =
                currentServings === 1 ? "persona" : "personas";

            updateButtons();

            valueElements.forEach((el) => {
              const elHtml = el as HTMLElement;
              const baseValue = parseFloat(elHtml.dataset.baseValue || "0");
              const scaleFactor = parseFloat(elHtml.dataset.scaleFactor || "1");
              const rawUnit = elHtml.dataset.unit || "";

              const incrementPerServing =
                (baseValue / baseServings) * scaleFactor;
              const diff = currentServings - baseServings;
              const newValue = baseValue + diff * incrementPerServing;

              const roundedValue = roundToKitchen(newValue, rawUnit);
              elHtml.textContent = roundedValue.toString();

              const unitEl = elHtml.nextElementSibling;
              if (unitEl && unitEl.classList.contains("ing-unit")) {
                unitEl.textContent =
                  " " + getDisplayUnit(roundedValue, rawUnit);
              }
            });
          };

          minusBtn.addEventListener("click", () => {
            if (currentServings > 1) {
              currentServings--;
              updateQuantities();
            }
          });

          plusBtn.addEventListener("click", () => {
            if (currentServings < 6) {
              currentServings++;
              updateQuantities();
            }
          });

          updateButtons();
        }
      },
    );
  }
</script>

<style>
  .recipe-stepper {
    font-family: "DMSans", sans-serif;
    margin: 1.5rem 0;
    padding: 1.25rem;
    border-radius: 12px;
    background: var(--input);
    border: 1px solid var(--border);
    color: var(--text);
  }

  .stepper-controls {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    padding-bottom: 1rem;
    font-weight: bold;
    color: var(--white);
    border-bottom: 1px solid var(--border);
  }

  .ingredients-title {
    font-size: 1.4rem;
    color: var(--links);
    margin: 1rem 0 0 0;
  }

  .servings-info {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    min-width: 100px;
    justify-content: center;
  }

  .stepper-controls button {
    font-family: inherit;
    width: 36px;
    height: 36px;
    border: 1px solid var(--border);
    background: var(--black);
    color: var(--white);
    border-radius: 50%;
    cursor: pointer;
    font-size: 1.2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
  }

  .stepper-controls button:hover:not(:disabled) {
    background: var(--border);
    border-color: var(--links);
  }

  .stepper-controls button:disabled {
    opacity: 0.2;
    cursor: not-allowed;
  }

  .ingredients-list {
    list-style: none;
    padding: 0;
    margin: 0;
    padding-top: 1rem;
  }

  .recipe-stepper:not(:has(.stepper-controls)) .ingredients-title {
    margin-top: 0rem;
  }

  .ingredients-list li {
    padding: 0.4rem 0;
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
  }

  .ing-name {
    color: var(--links);
  }

  .ing-value,
  .ing-value-fixed {
    font-variant-numeric: tabular-nums;
    font-weight: 600;
    color: var(--white);
  }

  .ing-unit {
    color: var(--text);
    opacity: 0.9;
    font-size: 0.95rem;
  }
</style>
