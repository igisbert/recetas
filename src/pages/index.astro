---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import { CATEGORIES, SITE_TITLE } from "@/constants/recipes";
import RecipeCard from "@/components/RecipeCard.astro";
import Filters from "@/components/Filters.astro";

const allRecipes = await getCollection("recipes");

const recipesByCategory = CATEGORIES.map((category) => {
  return {
    ...category,
    recipes: allRecipes.filter(
      (recipe) => recipe.data.category === category.id,
    ),
  };
}).filter((c) => c.recipes.length > 0);
---

<Layout title={SITE_TITLE}>
  <main class="index-container">
    <header class="main-header">
      <h1>{SITE_TITLE}</h1>
      <Filters categories={CATEGORIES} />
    </header>

    <div class="recipes-list" id="recipes-list">
      {
        recipesByCategory.map((group) => (
          <section class="category-section" data-category-id={group.id}>
            <h2
              id={group.id}
              style={`view-transition-name: category-${group.id}`}
            >
              {group.name}
            </h2>
            <ul class="recipe-list">
              {group.recipes.map((recipe) => (
                <RecipeCard recipe={recipe} />
              ))}
            </ul>
          </section>
        ))
      }
    </div>

    <div id="no-results" class="hidden">
      No se encontraron recetas con esos criterios.
    </div>
  </main>
</Layout>

<style is:global>
  @keyframes slide-down-blur-out {
    from {
      opacity: 1;
      transform: translateY(0) scale(1);
      filter: blur(0);
    }
    to {
      opacity: 0;
      transform: translateY(-20px) scale(1);
      filter: blur(4px);
    }
  }

  @keyframes fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  ::view-transition-old(.is-filtered) {
    animation: slide-down-blur-out 0.4s cubic-bezier(0.4, 0, 0.2, 1) forwards !important;
  }

  ::view-transition-new(*) {
    animation: fade-in 0.3s ease-out forwards;
  }

  ::view-transition-group(*) {
    animation-timing-function: cubic-bezier(0.4, 0, 0.2, 1);
    animation-duration: 0.4s;
  }
</style>

<style>
  .index-container {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .main-header {
    margin-bottom: 3rem;
  }

  h1 {
    font-size: 3rem;
    margin-bottom: 5rem;
    text-align: left;
    color: var(--white);
  }

  .category-section {
    margin-bottom: 1rem;
  }

  .category-section h2 {
    color: var(--white);
    border-bottom: 2px solid var(--border);
    padding-bottom: 0.5rem;
    margin-bottom: 0rem;
  }

  .category-section ul {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .hidden {
    display: none;
  }

  #no-results {
    padding: 2rem;
    text-align: center;
    font-style: italic;
    color: var(--text);
    opacity: 0.6;
  }
</style>
